{
  "expo": {
    "name": "pharmacy-mobile-app",
    "slug": "pharmacy-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/cosmic-log.png",
    "scheme": "pharmacymobileapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "splash": {
      "image": "./assets/images/cosmic-log.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/cosmic-log.png",
        "backgroundImage": "./assets/images/cosmic-log.png",
        "monochromeImage": "./assets/images/cosmic-log.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.cosmicforge.pharmacymobileapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiUrl": "https://dev-api.cosmicforge-healthnet.com/api",
      "socketUrl": "https://dev-api.cosmicforge-healthnet.com",
      "router": {},
      "eas": {
        "projectId": "dad57773-5ac0-4a9f-a00e-15a6e20a1d5d"
      }
    }
  }
}
